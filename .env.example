EXPENSES_ENV=Local
EXPENSES_DATA_DIR=./data
EXPENSES_TIMEZONE=Europe/Berlin

# First-time setup is always available while no users exist. Leave this blank
# for normal private installs, or set a random value to require X-Setup-Token
# during bootstrap setup.
EXPENSES_AUTH_SETUP_TOKEN=

# Self-service account signup is enabled by default after bootstrap. Set to
# false to restrict the app to existing accounts only.
EXPENSES_AUTH_SIGNUP_ENABLED=true

# Reverse-proxy trust. For Docker, EXPENSES_FORWARDED_ALLOW_IPS is passed to
# uvicorn's --forwarded-allow-ips. EXPENSES_TRUSTED_PROXY_IPS controls which
# direct client IPs the app trusts when reading X-Forwarded-Proto itself.
EXPENSES_FORWARDED_ALLOW_IPS=127.0.0.1
EXPENSES_TRUSTED_PROXY_IPS=

# Optional. If both are blank, the app generates and persists a secret under
# EXPENSES_DATA_DIR/secrets/csrf_secret.
EXPENSES_CSRF_SECRET=
EXPENSES_CSRF_SECRET_FILE=

# Transaction location maps use OpenStreetMap tiles by default. Set these to
# use a different tile provider, or set VITE_MAP_TILE_URL to an empty value
# (VITE_MAP_TILE_URL=) to render markers without external tile requests.
# VITE_MAP_TILE_URL=
# VITE_MAP_TILE_ATTRIBUTION=

EXPENSES_LLM_ENABLED=false
EXPENSES_LLM_BASE_URL=http://example-tailnet-host:8080/v1
EXPENSES_LLM_MODEL=qwen
EXPENSES_LLM_API_KEY=
EXPENSES_LLM_TEMPERATURE=
EXPENSES_LLM_MAX_OUTPUT_TOKENS=
